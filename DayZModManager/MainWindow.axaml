<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctl="using:DayZModManager.Controls"
        x:Class="DayZModManager.MainWindow"
        Title="DayZ Mod Manager // SCP LEGION"
        Width="1280"
        Height="820"
        MinWidth="1100"
        MinHeight="680"
        Background="{StaticResource Bg}"
        SystemDecorations="BorderOnly"
        WindowStartupLocation="CenterScreen"
        CanResize="True">

    <Border x:Name="WindowRootBorder"
            BorderBrush="{StaticResource Line2}"
            BorderThickness="1">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="28"/>
            <RowDefinition Height="34"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════ TITLE BAR ═══════════════ -->
        <Border Grid.Row="0"
                Background="{StaticResource Bg1}"
                BorderBrush="{StaticResource Line}"
                BorderThickness="0,0,0,1"
                PointerPressed="OnTitleBarPointerPressed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                    <TextBlock Text="▣" Foreground="{StaticResource Accent}" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                    <TextBlock Text=" DAYZ_MOD_MANAGER" Foreground="{StaticResource Text}"
                               FontSize="10" FontWeight="Bold" VerticalAlignment="Center" Margin="6,0,0,0"/>
                    <TextBlock Text=" // " Foreground="{StaticResource Muted}" FontSize="10" FontWeight="Bold" VerticalAlignment="Center"/>
                    <TextBlock Text="SCP_LEGION" Foreground="{StaticResource AccentDim}"
                               FontSize="10" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Stretch">
                    <Button x:Name="MinimizeButton"
                            Classes="TitleBarButton"
                            Content="─"
                            ToolTip.Tip="Minimize"
                            Click="OnMinimizeClick"/>
                    <Button x:Name="MaximizeButton"
                            Classes="TitleBarButton"
                            Content="▢"
                            ToolTip.Tip="Maximize"
                            Click="OnMaximizeRestoreClick"/>
                    <Button x:Name="CloseButton"
                            Classes="TitleBarCloseButton"
                            Content="✕"
                            ToolTip.Tip="Close"
                            Click="OnCloseClick"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════ TOPBAR ═══════════════ -->
        <Border Grid.Row="1"
                Background="{StaticResource Bg1}"
                BorderBrush="{StaticResource Line}"
                BorderThickness="0,0,0,1">
            <DockPanel LastChildFill="True" Margin="12,0">
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="[" Foreground="{StaticResource Line2}" FontWeight="Bold" FontSize="11"/>
                    <TextBlock Text="SCP" Foreground="{StaticResource Muted}" FontWeight="Bold" FontSize="11"/>
                    <TextBlock Text="] " Foreground="{StaticResource Line2}" FontWeight="Bold" FontSize="11"/>
                    <TextBlock Text="DAYZ" Foreground="{StaticResource Accent}" FontWeight="Bold" FontSize="11"/>
                    <TextBlock Text=" // " Foreground="{StaticResource Muted}" FontWeight="Bold" FontSize="11"/>
                    <TextBlock Text="MOD_MANAGER" Foreground="{StaticResource Text}" FontWeight="Bold" FontSize="11"/>

                    <Rectangle Width="1" Height="14" Fill="{StaticResource Line2}" Margin="14,0"/>

                    <Border Classes="PillGreen">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="6" Height="6" Fill="{StaticResource Accent}" VerticalAlignment="Center"/>
                            <TextBlock Text="PROTOCOL ACTIVE" Foreground="{StaticResource AccentDim}"
                                       FontSize="9" FontWeight="Bold" Margin="6,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Classes="PillCyan" Margin="6,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="6" Height="6" Fill="{StaticResource Cyan}" VerticalAlignment="Center"/>
                            <TextBlock Text="STEAM API · 200" Foreground="{StaticResource Cyan}"
                                       FontSize="9" FontWeight="Bold" Margin="6,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Classes="Pill">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="MODS.TXT" Foreground="{StaticResource Muted}" FontSize="9" FontWeight="Bold" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TopMods" Text="0" Foreground="{StaticResource Text}"
                                       FontSize="9" FontWeight="Bold" Margin="6,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Classes="PillGreen" Margin="6,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="INSTALLED" Foreground="{StaticResource AccentDim}" FontSize="9" FontWeight="Bold" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TopInstalled" Text="0" Foreground="{StaticResource Accent}"
                                       FontSize="9" FontWeight="Bold" Margin="6,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Rectangle Width="1" Height="14" Fill="{StaticResource Line2}" Margin="10,0"/>
                    <TextBlock x:Name="TopCrumb" Text="LOCAL_MODS" Foreground="{StaticResource Text}"
                               FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>

                <TextBlock x:Name="TopPathText" Text="" Foreground="{StaticResource Muted}"
                           FontSize="10" Margin="14,0,0,0" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- ═══════════════ BODY ═══════════════ -->
        <TabControl Grid.Row="2"
                    x:Name="MainTabs"
                    Classes="SidebarTabControl"
                    SelectionChanged="OnMainTabChanged">

            <!-- ════════ TAB 0: LOCAL MODS ════════ -->
            <TabItem>
                <TabItem.Header>
                    <TextBlock Text="&#x2261;" ToolTip.Tip="LOCAL MODS"/>
                </TabItem.Header>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="340"/>
                        <ColumnDefinition Width="1"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <DockPanel Grid.Column="0" Background="{StaticResource Bg1}" LastChildFill="True">
                        <Border DockPanel.Dock="Top" Classes="PanelBar">
                            <DockPanel LastChildFill="True">
                                <TextBlock Text="01" Foreground="{StaticResource Line2}" FontSize="9" VerticalAlignment="Center"/>
                                <TextBlock Text="  // INSTALLED MODS" Foreground="{StaticResource Muted}"
                                           FontSize="10" FontWeight="Bold" VerticalAlignment="Center"/>
                                <Border DockPanel.Dock="Right" Classes="Pill" HorizontalAlignment="Right">
                                    <TextBlock x:Name="LocalCountPill" Text="0" Foreground="{StaticResource Text}"
                                               FontSize="9" FontWeight="Bold" VerticalAlignment="Center"/>
                                </Border>
                            </DockPanel>
                        </Border>

                        <StackPanel DockPanel.Dock="Top" Margin="10,10,10,8">
                            <TextBlock Text="// MODS FILE" Classes="SectionLabel" Margin="0,0,0,6"/>
                            <DockPanel LastChildFill="True" Margin="0,0,0,8">
                                <Button Content="BROWSE" DockPanel.Dock="Right" Width="72" Margin="6,0,0,0" Click="OnBrowseLocalFile"/>
                                <TextBox x:Name="LocalFilePathTextBox"/>
                            </DockPanel>

                            <TextBlock Text="// STEAM WEB API KEY (OPTIONAL)" Classes="SectionLabel" Margin="0,4,0,6"/>
                            <TextBox x:Name="LocalApiKeyTextBox" Margin="0,0,0,8"/>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <CheckBox x:Name="LocalLookupCheckBox" Content="lookup titles"/>
                                <CheckBox x:Name="LocalShowInstalledCheckBox" Content="show installed" IsChecked="True" Margin="14,0,0,0"/>
                            </StackPanel>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="6"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Classes="BtnGreen" Content="⟳ REFRESH" Click="OnRefreshLocal"/>
                                <Button Grid.Column="2" Classes="BtnRed"   Content="✕ REMOVE"  Click="OnRemoveSelected"/>
                            </Grid>
                        </StackPanel>

                        <Border DockPanel.Dock="Bottom"
                                Background="{StaticResource Bg1}"
                                BorderBrush="{StaticResource Line}"
                                BorderThickness="0,1,0,0"
                                Padding="12,6">
                            <TextBlock x:Name="LocalStatusTextBlock" Foreground="{StaticResource Muted}" FontSize="10"/>
                        </Border>

                        <ListBox x:Name="LocalIdsListBox" SelectionMode="Single" BorderThickness="0" Background="Transparent"/>
                    </DockPanel>

                    <Rectangle Grid.Column="1" Fill="{StaticResource Line}"/>

                    <DockPanel Grid.Column="2" Background="{StaticResource Bg}" LastChildFill="True">
                        <Border DockPanel.Dock="Top" Classes="PanelBar">
                            <DockPanel LastChildFill="True">
                                <TextBlock Text="02" Foreground="{StaticResource Line2}" FontSize="9" VerticalAlignment="Center"/>
                                <TextBlock Text="  // MOD DETAIL" Foreground="{StaticResource Muted}"
                                           FontSize="10" FontWeight="Bold" VerticalAlignment="Center"/>
                                <Border DockPanel.Dock="Right" Classes="PillGreen" HorizontalAlignment="Right">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="6" Height="6" Fill="{StaticResource Accent}" VerticalAlignment="Center"/>
                                        <TextBlock Text="LOADED" Foreground="{StaticResource AccentDim}"
                                                   FontSize="9" FontWeight="Bold" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </DockPanel>
                        </Border>

                        <Border DockPanel.Dock="Bottom"
                                Background="{StaticResource Bg1}"
                                BorderBrush="{StaticResource Line}"
                                BorderThickness="0,1,0,0"
                                Padding="14,8">
                            <TextBlock x:Name="LocalFooterTextBlock" Foreground="{StaticResource Muted}" FontSize="10"/>
                        </Border>

                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="22,18">
                            <StackPanel>
                                <Grid Margin="0,0,0,18">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="96"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="96" Height="96"
                                            Background="{StaticResource Bg2}"
                                            BorderBrush="{StaticResource Line2}" BorderThickness="1">
                                        <TextBlock Text="DZ" Foreground="{StaticResource AccentDim}"
                                                   FontSize="26" FontWeight="Bold"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="2" VerticalAlignment="Top">
                                        <TextBlock x:Name="DetailTitleText" Text="(select a mod)"
                                                   Foreground="{StaticResource Text}"
                                                   FontSize="16" FontWeight="Bold"/>
                                        <TextBlock x:Name="DetailIdText" Text="// no selection"
                                                   Foreground="{StaticResource Muted}" FontSize="10" Margin="0,2,0,10"/>
                                        <WrapPanel>
                                            <Border Classes="PillGreen" Margin="0,0,6,4">
                                                <StackPanel Orientation="Horizontal">
                                                    <Ellipse Width="6" Height="6" Fill="{StaticResource Accent}" VerticalAlignment="Center"/>
                                                    <TextBlock Text="ACTIVE" Foreground="{StaticResource AccentDim}"
                                                               FontSize="9" FontWeight="Bold" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                            <Border Classes="Pill" Margin="0,0,6,4">
                                                <TextBlock Text="WORKSHOP" Foreground="{StaticResource Dim}" FontSize="9" FontWeight="Bold" VerticalAlignment="Center"/>
                                            </Border>
                                            <Border Classes="PillCyan" Margin="0,0,6,4">
                                                <TextBlock Text="@CHERNARUS" Foreground="{StaticResource Cyan}" FontSize="9" FontWeight="Bold" VerticalAlignment="Center"/>
                                            </Border>
                                        </WrapPanel>
                                    </StackPanel>
                                </Grid>

                                <Border BorderBrush="{StaticResource Line}" BorderThickness="0,1,0,0" Padding="0,12,0,0">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="PATH" Foreground="{StaticResource Muted}" FontSize="10" FontWeight="Bold"/>
                                            <TextBlock x:Name="DetailPathText" Grid.Column="1" Text="—" Foreground="{StaticResource Text}" FontSize="10"/>
                                        </Grid>
                                        <Grid Margin="0,0,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="INSTALLED" Foreground="{StaticResource Muted}" FontSize="10" FontWeight="Bold"/>
                                            <TextBlock x:Name="DetailInstalledText" Grid.Column="1" Text="—" Foreground="{StaticResource Text}" FontSize="10"/>
                                        </Grid>
                                        <Grid Margin="0,0,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="WORKSHOP ID" Foreground="{StaticResource Muted}" FontSize="10" FontWeight="Bold"/>
                                            <TextBlock x:Name="DetailWsIdText" Grid.Column="1" Text="—" Foreground="{StaticResource Text}" FontSize="10"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <Border BorderBrush="{StaticResource Line}" BorderThickness="0,1,0,0" Padding="0,14,0,0" Margin="0,14,0,0">
                                    <TextBlock Text="// Tip: select an ID on the left to see workshop links and remove options. Use the SEARCH WORKSHOP tab to add new mods."
                                               Foreground="{StaticResource Muted}" FontSize="10" TextWrapping="Wrap"/>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </DockPanel>
                </Grid>
            </TabItem>

            <!-- ════════ TAB 1: SEARCH WORKSHOP ════════ -->
            <TabItem>
                <TabItem.Header>
                    <TextBlock Text="&#x2315;" ToolTip.Tip="SEARCH WORKSHOP"/>
                </TabItem.Header>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="1"/>
                        <ColumnDefinition Width="360"/>
                    </Grid.ColumnDefinitions>

                    <DockPanel Grid.Column="0" LastChildFill="True">
                        <Border DockPanel.Dock="Top"
                                Background="{StaticResource Bg1}"
                                BorderBrush="{StaticResource Line}"
                                BorderThickness="0,0,0,1"
                                Padding="16,14">
                            <StackPanel>
                                <TextBlock Text="// STEAM WORKSHOP SEARCH" Classes="SectionLabel" Margin="0,0,0,8"/>

                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="14"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="14"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="100"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="appid" Foreground="{StaticResource Muted}" FontSize="10" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBox   Grid.Column="1" x:Name="AppIdTextBox" Text="221100"/>
                                    <TextBlock Grid.Column="3" Text="creator" Foreground="{StaticResource Muted}" FontSize="10" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBox   Grid.Column="4" x:Name="CreatorAppIdTextBox" Text="221100"/>
                                    <TextBox   Grid.Column="6" x:Name="SearchTextBox"/>
                                    <Button    Grid.Column="8" Classes="BtnGreen" Content="⌕ SEARCH" Click="OnSearchWorkshop"/>
                                </Grid>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="170"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="240"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="sort:" Foreground="{StaticResource Muted}" FontSize="10" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <ComboBox  Grid.Column="1" x:Name="WorkshopSortComboBox" SelectedIndex="0">
                                        <ComboBoxItem Content="Relevance"/>
                                        <ComboBoxItem Content="Title (A-Z)"/>
                                        <ComboBoxItem Content="Title (Z-A)"/>
                                        <ComboBoxItem Content="ID (asc)"/>
                                    </ComboBox>
                                    <CheckBox  Grid.Column="3" x:Name="HideInModsCheckBox"  Content="hide in mods.txt"/>
                                    <CheckBox  Grid.Column="5" x:Name="AutoAddDepsCheckBox" Content="auto-add deps" IsChecked="True"/>
                                    <TextBlock Grid.Column="7" Text="api key:" Foreground="{StaticResource Muted}" FontSize="10" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBox   Grid.Column="8" x:Name="SearchApiKeyTextBox"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border DockPanel.Dock="Bottom"
                                Background="{StaticResource Bg1}"
                                BorderBrush="{StaticResource Line}"
                                BorderThickness="0,1,0,0"
                                Padding="12,8">
                            <DockPanel LastChildFill="True">
                                <Button DockPanel.Dock="Left" Classes="BtnGreen" Content="⊕ ADD SELECTED"  Click="OnAddSelected" Margin="0,0,6,0" Width="160"/>
                                <Button DockPanel.Dock="Left" Content="▦ DEPENDENCY TREE" Click="OnShowDependencyTree" Width="180"/>
                                <TextBlock x:Name="AddStatusTextBlock" Foreground="{StaticResource Muted}" FontSize="10"
                                           VerticalAlignment="Center" Margin="14,0,0,0"/>
                            </DockPanel>
                        </Border>

                        <ListBox x:Name="SearchResultsListBox" SelectionMode="Single"
                                 BorderThickness="0" Background="Transparent" Padding="6">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource Bg1}"
                                            BorderBrush="{StaticResource Line}"
                                            BorderThickness="1"
                                            Padding="12" Margin="2,4">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}"       Foreground="{StaticResource Text}"  FontWeight="Bold" FontSize="12" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding Description}" Foreground="{StaticResource Muted}" FontSize="10"     Margin="0,6,0,0" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding PublishedFileId}" Foreground="{StaticResource AccentDim}" FontSize="10" Margin="0,8,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>

                    <Rectangle Grid.Column="1" Fill="{StaticResource Line}"/>

                    <DockPanel Grid.Column="2" Background="{StaticResource Bg1}" LastChildFill="True">
                        <Border DockPanel.Dock="Top" Classes="PanelBar">
                            <DockPanel LastChildFill="True">
                                <TextBlock Text="03" Foreground="{StaticResource Line2}" FontSize="9" VerticalAlignment="Center"/>
                                <TextBlock Text="  // MODS.TXT" Foreground="{StaticResource Muted}"
                                           FontSize="10" FontWeight="Bold" VerticalAlignment="Center"/>
                            </DockPanel>
                        </Border>

                        <StackPanel DockPanel.Dock="Top" Margin="12,10,12,8">
                            <TextBlock Text="// BULK ADD (ONE ID PER LINE)" Classes="SectionLabel" Margin="0,0,0,6"/>
                            <TextBox x:Name="BulkIdsTextBox" Height="92"
                                     AcceptsReturn="True" TextWrapping="NoWrap"/>
                            <Button Classes="BtnGreen" Content="⊕ ADD BULK TO MODS.TXT"
                                    Click="OnAddBulk" Margin="0,8,0,4" HorizontalAlignment="Stretch"/>

                            <TextBlock Text="// LOOKUP" Classes="SectionLabel" Margin="0,8,0,6"/>
                            <CheckBox x:Name="ModsLookupCheckBox" Content="lookup titles in mods.txt"/>
                            <TextBox x:Name="ModsApiKeyTextBox" Margin="0,6,0,0"/>
                            <Button Content="⟳ REFRESH" Click="OnRefreshModsList" Margin="0,8,0,0"/>
                        </StackPanel>

                        <Border DockPanel.Dock="Bottom"
                                Background="{StaticResource Bg1}"
                                BorderBrush="{StaticResource Line}"
                                BorderThickness="0,1,0,0"
                                Padding="12,6">
                            <TextBlock x:Name="ModsStatusTextBlock" Foreground="{StaticResource Muted}" FontSize="10"/>
                        </Border>

                        <ListBox x:Name="ModsListBox" BorderThickness="0" Background="Transparent"/>
                    </DockPanel>
                </Grid>
            </TabItem>

            <!-- ════════ TAB 2: MOD FOLDERS / TYPES.XML ════════ -->
            <TabItem>
                <TabItem.Header>
                    <TextBlock Text="&#x25A6;" ToolTip.Tip="MOD FOLDERS · TYPES.XML"/>
                </TabItem.Header>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{StaticResource Bg1}"
                            BorderBrush="{StaticResource Line}"
                            BorderThickness="0,0,0,1"
                            Padding="16,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="6"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="6"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="6"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="MODS ROOT:" Foreground="{StaticResource Muted}"
                                       FontSize="10" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBox  Grid.Column="1" x:Name="ModsRootTextBox"/>
                            <Button   Grid.Column="3" Content="BROWSE"   Click="OnBrowseModsRoot"    Width="80"/>
                            <Button   Grid.Column="5" Content="⟳ REFRESH" Click="OnRefreshModFolders" Width="100"/>
                            <Button   Grid.Column="7" Classes="BtnGreen"
                                      Content="💾 SAVE SETTINGS" Click="OnSaveSettings" Width="150"/>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="340"/>
                            <ColumnDefinition Width="1"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <DockPanel Grid.Column="0" Background="{StaticResource Bg1}" LastChildFill="True">
                            <ScrollViewer DockPanel.Dock="Top"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          MaxHeight="430">
                            <StackPanel Margin="12,12,12,8">
                                <TextBlock Text="// XML COMBINER" Classes="SectionLabel" Margin="0,0,0,8"/>
                                <CheckBox x:Name="CombineAllCheckBox" Content="combine matching files across mods" IsChecked="True"
                                          IsCheckedChanged="OnCombineAllChanged"/>

                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="PRESET:" Foreground="{StaticResource Muted}"
                                               FontSize="10" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <ComboBox  Grid.Column="1" x:Name="PresetComboBox"
                                               SelectionChanged="OnPresetSelected"
                                               DisplayMemberPath="DisplayName"/>
                                </Grid>

                                <TextBlock x:Name="PresetDescriptionText"
                                           Foreground="{StaticResource Sub}"
                                           FontSize="10"
                                           TextWrapping="Wrap"
                                           Margin="0,6,0,0"/>

                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="MERGE:" Foreground="{StaticResource Muted}"
                                               FontSize="10" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <ComboBox  Grid.Column="1" x:Name="MergeModeComboBox" SelectedIndex="0">
                                        <ComboBoxItem Content="Dedupe-first (by name)"/>
                                        <ComboBoxItem Content="Append (keep all)"/>
                                        <ComboBoxItem Content="Dedupe-last (by name)"/>
                                    </ComboBox>
                                </Grid>

                                <TextBlock Text="INCLUDE (glob, comma-sep):" Foreground="{StaticResource Muted}"
                                           FontSize="10" FontWeight="Bold" Margin="0,8,0,2"/>
                                <TextBox x:Name="IncludePatternsTextBox"/>

                                <TextBlock Text="EXCLUDE (glob, comma-sep):" Foreground="{StaticResource Muted}"
                                           FontSize="10" FontWeight="Bold" Margin="0,6,0,2"/>
                                <TextBox x:Name="ExcludePatternsTextBox"/>

                                <Grid Margin="0,6,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="ROOT ELEM:" Foreground="{StaticResource Muted}"
                                                   FontSize="10" FontWeight="Bold" Margin="0,0,0,2"/>
                                        <TextBox x:Name="RootElementTextBox"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="KEY ATTR:" Foreground="{StaticResource Muted}"
                                                   FontSize="10" FontWeight="Bold" Margin="0,0,0,2"/>
                                        <TextBox x:Name="KeyAttributeTextBox"/>
                                    </StackPanel>
                                </Grid>

                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="OUT:" Foreground="{StaticResource Muted}"
                                               FontSize="10" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBox   Grid.Column="1" x:Name="CombineOutFileTextBox" Text="types.xml"/>
                                </Grid>

                                <TextBlock Text="// EXCLUDE DIRS (one mod folder per line, e.g. @CF)"
                                           Classes="SectionLabel" Margin="0,10,0,4"/>
                                <TextBox x:Name="XmlGenExcludeDirsTextBox"
                                         AcceptsReturn="True"
                                         TextWrapping="NoWrap"
                                         MinHeight="48" MaxHeight="120"
                                         ToolTip.Tip="Mod-folder leaf names to skip during XML auto-generation. Case-insensitive. Lines starting with # are ignored."/>

                                <Button Classes="BtnGreen" Content="▶ COMBINE FILES"
                                        Click="OnGenerateCombinedTypes" Margin="0,10,0,0"/>
                                <Button Content="◑ PREVIEW (DRY-RUN)"
                                        Click="OnPreviewCombinedTypes" Margin="0,6,0,0"/>
                            </StackPanel>
                            </ScrollViewer>

                            <Border DockPanel.Dock="Bottom"
                                    Background="{StaticResource Bg2}"
                                    BorderBrush="{StaticResource Line}"
                                    BorderThickness="0,1,0,0"
                                    Padding="12,10">
                                <StackPanel>
                                    <TextBlock Text="// PROFILES" Classes="SectionLabel" Margin="0,0,0,6"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="6"/>
                                            <ColumnDefinition Width="74"/>
                                            <ColumnDefinition Width="6"/>
                                            <ColumnDefinition Width="74"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" x:Name="ProfileNameTextBox" Text="default"/>
                                        <Button  Grid.Column="2" Content="EXPORT" Click="OnExportProfile"/>
                                        <Button  Grid.Column="4" Content="IMPORT" Click="OnImportProfile"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border DockPanel.Dock="Top"
                                    BorderBrush="{StaticResource Line}"
                                    BorderThickness="0,1,0,1"
                                    Padding="12,8">
                                <TextBlock Text="// MOD FOLDERS" Classes="SectionLabel"/>
                            </Border>

                            <ListBox x:Name="ModFoldersListBox"
                                     SelectionMode="Single"
                                     SelectionChanged="OnModFolderSelected"
                                     BorderThickness="0" Background="Transparent"/>
                        </DockPanel>

                        <Rectangle Grid.Column="1" Fill="{StaticResource Line}"/>

                        <DockPanel Grid.Column="2" Background="{StaticResource Bg}" LastChildFill="True">
                            <Border DockPanel.Dock="Top" Classes="PanelBar">
                                <DockPanel LastChildFill="True">
                                    <TextBlock Text="04" Foreground="{StaticResource Line2}" FontSize="9" VerticalAlignment="Center"/>
                                    <TextBlock Text="  // FOLDER DETAILS" Foreground="{StaticResource Muted}"
                                               FontSize="10" FontWeight="Bold" VerticalAlignment="Center"/>
                                </DockPanel>
                            </Border>

                            <TextBox x:Name="FolderDetailsTextBox"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     Background="{StaticResource Bg}"
                                     BorderThickness="0"
                                     Padding="14"
                                     FontFamily="{StaticResource MonoFont}"
                                     FontSize="11"
                                     Foreground="{StaticResource Sub}"/>
                        </DockPanel>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ════════ TAB 3: SERVER ════════ -->
            <TabItem>
                <TabItem.Header>
                    <TextBlock Text="&#x2630;" ToolTip.Tip="SERVER"/>
                </TabItem.Header>
                <DockPanel LastChildFill="True">
                    <Border DockPanel.Dock="Top" Classes="PanelBar">
                        <DockPanel LastChildFill="True">
                            <TextBlock Text="07" Foreground="{StaticResource Line2}" FontSize="9" VerticalAlignment="Center"/>
                            <TextBlock Text="  // SERVER" Foreground="{StaticResource Muted}"
                                       FontSize="10" FontWeight="Bold" VerticalAlignment="Center"/>
                            <Border DockPanel.Dock="Right" x:Name="ServerStatusPill"
                                    Classes="Pill" HorizontalAlignment="Right">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse x:Name="ServerStatusDot" Width="6" Height="6"
                                             Fill="{StaticResource Muted}" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="ServerStateText" Text="STOPPED"
                                               Foreground="{StaticResource Muted}"
                                               FontSize="9" FontWeight="Bold" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="ServerPidText" Text=""
                                               Foreground="{StaticResource Sub}"
                                               FontSize="9" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="ServerUptimeText" Text=""
                                               Foreground="{StaticResource Sub}"
                                               FontSize="9" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </DockPanel>
                    </Border>

                    <Border DockPanel.Dock="Top"
                            Background="{StaticResource Bg1}"
                            BorderBrush="{StaticResource Line}"
                            BorderThickness="0,0,0,1"
                            Padding="12,10">
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="ServerStartButton" Classes="BtnGreen"
                                    Content="▶ START" Width="120" Click="OnServerStart"/>
                            <Button x:Name="ServerStopButton" Classes="BtnRed"
                                    Content="■ STOP" Width="100" Margin="6,0,0,0"
                                    Click="OnServerStop" IsEnabled="False"/>
                            <Button x:Name="ServerRestartButton" Content="↻ RESTART"
                                    Width="120" Margin="6,0,0,0"
                                    Click="OnServerRestart" IsEnabled="False"/>
                            <Rectangle Width="1" Height="16" Fill="{StaticResource Line2}" Margin="14,0"/>
                            <Button x:Name="ServerUpdateModsButton" Content="⇩ UPDATE MODS"
                                    Width="160" Click="OnUpdateModsClicked"/>
                            <Button x:Name="ServerReauthButton" Content="🔑 RE-AUTHENTICATE"
                                    Width="180" Margin="6,0,0,0" Click="OnReauthClicked"/>
                            <TextBlock x:Name="ServerActionStatusText" Foreground="{StaticResource Muted}"
                                       FontSize="10" VerticalAlignment="Center" Margin="14,0,0,0"/>
                        </StackPanel>
                    </Border>

                    <Expander DockPanel.Dock="Top" Header="// SETUP" IsExpanded="True"
                              Foreground="{StaticResource Muted}" Margin="12,8,12,0">
                        <StackPanel Margin="0,8,0,0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="MODE:" Foreground="{StaticResource Muted}"
                                           FontSize="10" FontWeight="Bold" VerticalAlignment="Center"
                                           Margin="0,0,8,0"/>
                                <RadioButton x:Name="ModePs1Radio" Content="invoke servermanager.ps1"
                                             GroupName="ServerMode"
                                             Margin="0,0,14,0"
                                             IsCheckedChanged="OnServerModeChanged"/>
                                <RadioButton x:Name="ModeDirectRadio" Content="launch DayZServer_x64.exe directly"
                                             GroupName="ServerMode"
                                             IsChecked="True"
                                             IsCheckedChanged="OnServerModeChanged"/>
                            </StackPanel>

                            <StackPanel x:Name="ModePs1Panel" IsVisible="False">
                                <TextBlock Text="// SERVERMANAGER.PS1" Classes="SectionLabel" Margin="0,4,0,4"/>
                                <DockPanel LastChildFill="True" Margin="0,0,0,8">
                                    <Button DockPanel.Dock="Right" Content="BROWSE" Width="72" Margin="6,0,0,0"
                                            Click="OnServerBrowsePs1"/>
                                    <TextBox x:Name="ServerPs1PathTextBox"/>
                                </DockPanel>

                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="14"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="14"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="120"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="-launchParam:" Foreground="{StaticResource Muted}"
                                               FontSize="10" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <ComboBox Grid.Column="1" x:Name="Ps1LaunchParamComboBox" SelectedIndex="0">
                                        <ComboBoxItem Content="default"/>
                                        <ComboBoxItem Content="user"/>
                                    </ComboBox>
                                    <TextBlock Grid.Column="3" Text="-app:" Foreground="{StaticResource Muted}"
                                               FontSize="10" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <ComboBox Grid.Column="4" x:Name="Ps1AppBranchComboBox" SelectedIndex="0">
                                        <ComboBoxItem Content="stable"/>
                                        <ComboBoxItem Content="exp"/>
                                    </ComboBox>
                                    <TextBlock Grid.Column="6" Text="-update:" Foreground="{StaticResource Muted}"
                                               FontSize="10" VerticalAlignment="Center" Margin="0,0,6,0"
                                               ToolTip.Tip="Used by UPDATE MODS button in ps1 mode"/>
                                    <ComboBox Grid.Column="7" x:Name="Ps1UpdateTargetComboBox" SelectedIndex="2">
                                        <ComboBoxItem Content="server"/>
                                        <ComboBoxItem Content="mod"/>
                                        <ComboBoxItem Content="all"/>
                                    </ComboBox>
                                </Grid>
                            </StackPanel>

                            <StackPanel x:Name="ModeDirectPanel">
                                <TextBlock Text="// DAYZSERVER_X64.EXE" Classes="SectionLabel" Margin="0,4,0,4"/>
                                <DockPanel LastChildFill="True" Margin="0,0,0,6">
                                    <Button DockPanel.Dock="Right" Content="BROWSE" Width="72" Margin="6,0,0,0"
                                            Click="OnServerBrowseExe"/>
                                    <TextBox x:Name="ServerExePathTextBox"/>
                                </DockPanel>

                                <TextBlock Text="// SERVER PROFILE DIR (RPT logs)" Classes="SectionLabel" Margin="0,4,0,4"/>
                                <DockPanel LastChildFill="True" Margin="0,0,0,6">
                                    <Button DockPanel.Dock="Right" Content="BROWSE" Width="72" Margin="6,0,0,0"
                                            Click="OnServerBrowseProfile"/>
                                    <TextBox x:Name="ServerProfileDirTextBox"/>
                                </DockPanel>

                                <TextBlock Text="// SERVER ROOT DIR (@mod deploy target)" Classes="SectionLabel" Margin="0,4,0,4"/>
                                <DockPanel LastChildFill="True" Margin="0,0,0,6">
                                    <Button DockPanel.Dock="Right" Content="BROWSE" Width="72" Margin="6,0,0,0"
                                            Click="OnServerBrowseRoot"/>
                                    <TextBox x:Name="ServerRootDirTextBox"
                                             ToolTip.Tip="Where @modname junctions/symlinks/copies are placed. Defaults to the folder containing the server exe."/>
                                </DockPanel>

                                <Grid Margin="0,4,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="14"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="14"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="port:" Foreground="{StaticResource Muted}"
                                               FontSize="10" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBox Grid.Column="1" x:Name="ServerPortTextBox" Text="2302"/>
                                    <TextBlock Grid.Column="3" Text="extra args:" Foreground="{StaticResource Muted}"
                                               FontSize="10" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBox Grid.Column="4" x:Name="ServerExtraArgsTextBox"/>
                                    <CheckBox Grid.Column="6" x:Name="ServerBattlEyeCheckBox"
                                              Content="BattlEye" IsChecked="True"/>
                                </Grid>

                                <Border BorderBrush="{StaticResource Line}" BorderThickness="0,1,0,0" Padding="0,10,0,0" Margin="0,8,0,0">
                                    <StackPanel>
                                        <TextBlock Text="// STEAMCMD" Classes="SectionLabel" Margin="0,0,0,6"/>

                                        <TextBlock Text="STEAMCMD.EXE PATH" Classes="SectionLabel" Margin="0,4,0,4"/>
                                        <DockPanel LastChildFill="True" Margin="0,0,0,6">
                                            <Button DockPanel.Dock="Right" Content="BROWSE" Width="72" Margin="6,0,0,0"
                                                    Click="OnServerBrowseSteamCmd"/>
                                            <TextBox x:Name="SteamCmdPathTextBox"/>
                                        </DockPanel>

                                        <TextBlock Text="MOD CACHE DIR (auto = SteamCMD dir; workshop content lives under it)"
                                                   Classes="SectionLabel" Margin="0,4,0,4"/>
                                        <DockPanel LastChildFill="True" Margin="0,0,0,6">
                                            <Button DockPanel.Dock="Right" Content="BROWSE" Width="72" Margin="6,0,0,0"
                                                    IsEnabled="False"
                                                    Click="OnServerBrowseModCache"/>
                                            <TextBox x:Name="ModCacheDirTextBox"
                                                     IsReadOnly="True"
                                                     ToolTip.Tip="Auto-derived from steamcmd.exe path. Workshop content goes to &lt;dir&gt;/steamapps/workshop/content/&lt;appid&gt;/..., then is copied/linked into the server root."/>
                                        </DockPanel>

                                        <Grid Margin="0,4,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="14"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="120"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="LOGIN:" Foreground="{StaticResource Muted}"
                                                       FontSize="10" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                <RadioButton x:Name="LoginAnonymousRadio" Content="anonymous"
                                                             GroupName="LoginMode"
                                                             Margin="0,0,14,0"/>
                                                <RadioButton x:Name="LoginInteractiveRadio" Content="interactive (Steam account)"
                                                             GroupName="LoginMode"
                                                             IsChecked="True"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="3" Text="username:" Foreground="{StaticResource Muted}"
                                                       FontSize="10" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBox Grid.Column="4" x:Name="SteamLoginTextBox"/>
                                        </Grid>

                                        <TextBlock TextWrapping="Wrap" Foreground="{StaticResource Sub}" FontSize="10" Margin="0,0,0,8">
                                            DayZ Workshop items require a Steam account that owns DayZ — anonymous login does not work.
                                            On first run (or after Re-authenticate) SteamCMD opens in its own console window for you to
                                            type your password and Steam Guard code there. The manager never sees or stores your password.
                                        </TextBlock>

                                        <Grid Margin="0,0,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="14"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="140"/>
                                                <ColumnDefinition Width="14"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="appid:" Foreground="{StaticResource Muted}"
                                                       FontSize="10" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBox Grid.Column="1" x:Name="WorkshopAppIdTextBox" Text="221100"/>
                                            <TextBlock Grid.Column="3" Text="deploy:" Foreground="{StaticResource Muted}"
                                                       FontSize="10" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <ComboBox Grid.Column="4" x:Name="DeployModeComboBox" SelectedIndex="0">
                                                <ComboBoxItem Content="Junction"/>
                                                <ComboBoxItem Content="Symlink"/>
                                                <ComboBoxItem Content="Copy"/>
                                            </ComboBox>
                                            <StackPanel Grid.Column="6" Orientation="Horizontal">
                                                <CheckBox x:Name="ValidateModsCheckBox" Content="validate"/>
                                                <CheckBox x:Name="AutoUpdateBeforeStartCheckBox"
                                                          Content="auto-update before start" Margin="14,0,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <Border BorderBrush="{StaticResource Line}" BorderThickness="0,1,0,0" Padding="0,10,0,0" Margin="0,8,0,0">
                                <StackPanel>
                                    <TextBlock Text="// AUTO-RESTART" Classes="SectionLabel" Margin="0,0,0,6"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="14"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="14"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="80"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0" x:Name="AutoRestartCheckBox" Content="restart on crash"/>
                                        <TextBlock Grid.Column="2" Text="backoff (s):" Foreground="{StaticResource Muted}"
                                                   FontSize="10" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBox Grid.Column="3" x:Name="AutoRestartBackoffTextBox" Text="10"/>
                                        <TextBlock Grid.Column="5" Text="max retries:" Foreground="{StaticResource Muted}"
                                                   FontSize="10" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBox Grid.Column="6" x:Name="AutoRestartMaxRetriesTextBox" Text="3"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border BorderBrush="{StaticResource Line}" BorderThickness="0,1,0,0" Padding="0,10,0,0" Margin="0,8,0,0">
                                <StackPanel>
                                    <TextBlock Text="// PRE-START XML MERGE" Classes="SectionLabel" Margin="0,0,0,6"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="14"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0" x:Name="PreStartMergeCheckBox" Content="regenerate types.xml before start"/>
                                        <TextBlock Grid.Column="2" Text="preset:" Foreground="{StaticResource Muted}"
                                                   FontSize="10" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <ComboBox Grid.Column="3" x:Name="PreStartPresetComboBox"
                                                  DisplayMemberPath="DisplayName"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border BorderBrush="{StaticResource Line}" BorderThickness="0,1,0,0" Margin="0,10,0,0" Padding="0,10,0,0">
                                <Button Classes="BtnGreen" Content="💾 SAVE SERVER SETTINGS"
                                        HorizontalAlignment="Left" Width="220" Click="OnSaveSettings"/>
                            </Border>
                        </StackPanel>
                    </Expander>

                    <Border DockPanel.Dock="Top"
                            Background="{StaticResource Bg1}"
                            BorderBrush="{StaticResource Line}"
                            BorderThickness="0,1,0,1"
                            Padding="12,6"
                            Margin="0,8,0,0">
                        <DockPanel LastChildFill="True">
                            <Button DockPanel.Dock="Right" Content="CLEAR" Width="72"
                                    Margin="6,0,0,0" Click="OnClearLog"/>
                            <CheckBox DockPanel.Dock="Right" x:Name="PauseAutoscrollCheckBox"
                                      Content="pause autoscroll" VerticalAlignment="Center" Margin="14,0,0,0"/>
                            <ComboBox DockPanel.Dock="Right" x:Name="LogSourceComboBox" Width="160" SelectedIndex="0"
                                      SelectionChanged="OnLogSourceChanged">
                                <ComboBoxItem Content="RPT tail"/>
                                <ComboBoxItem Content="SteamCMD output"/>
                            </ComboBox>
                            <TextBlock Text="source:" Foreground="{StaticResource Muted}"
                                       FontSize="10" VerticalAlignment="Center" Margin="0,0,6,0"
                                       DockPanel.Dock="Right"/>
                            <TextBlock x:Name="ActiveLogFileText" Text="(no log)"
                                       Foreground="{StaticResource Sub}" FontSize="10" VerticalAlignment="Center"/>
                        </DockPanel>
                    </Border>

                    <TextBox x:Name="ServerLogTextBox"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             TextWrapping="NoWrap"
                             Background="{StaticResource Bg}"
                             BorderThickness="0"
                             Padding="14"
                             FontFamily="{StaticResource MonoFont}"
                             FontSize="11"
                             Foreground="{StaticResource Sub}"/>
                </DockPanel>
            </TabItem>

            <!-- ════════ TAB 4: HISTORY ════════ -->
            <TabItem>
                <TabItem.Header>
                    <TextBlock Text="&#x21BA;" ToolTip.Tip="HISTORY"/>
                </TabItem.Header>
                <DockPanel LastChildFill="True">
                    <Border DockPanel.Dock="Top" Classes="PanelBar">
                        <DockPanel LastChildFill="True">
                            <TextBlock Text="05" Foreground="{StaticResource Line2}" FontSize="9" VerticalAlignment="Center"/>
                            <TextBlock Text="  // MODS.TXT HISTORY" Foreground="{StaticResource Muted}"
                                       FontSize="10" FontWeight="Bold" VerticalAlignment="Center"/>
                            <Button DockPanel.Dock="Right" HorizontalAlignment="Right"
                                    Content="⟳ REFRESH HISTORY" Click="OnRefreshHistory" Width="180" Margin="6,5"/>
                        </DockPanel>
                    </Border>

                    <ListBox x:Name="HistoryListBox" BorderThickness="0" Background="Transparent" Padding="6"/>
                </DockPanel>
            </TabItem>

            <!-- ════════ TAB 5: AI BALANCER ════════ -->
            <TabItem>
                <TabItem.Header>
                    <TextBlock Text="&#x2728;" ToolTip.Tip="AI BALANCER"/>
                </TabItem.Header>
                <ctl:AiBalancerTab/>
            </TabItem>

            <!-- ════════ TAB 6: SETTINGS ════════ -->
            <TabItem>
                <TabItem.Header>
                    <TextBlock Text="&#x2699;" ToolTip.Tip="SETTINGS"/>
                </TabItem.Header>
                <DockPanel LastChildFill="True">
                    <Border DockPanel.Dock="Top" Classes="PanelBar">
                        <DockPanel LastChildFill="True">
                            <TextBlock Text="06" Foreground="{StaticResource Line2}" FontSize="9" VerticalAlignment="Center"/>
                            <TextBlock Text="  // SETTINGS" Foreground="{StaticResource Muted}"
                                       FontSize="10" FontWeight="Bold" VerticalAlignment="Center"/>
                        </DockPanel>
                    </Border>

                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="36,28">
                        <Grid MaxWidth="1100" HorizontalAlignment="Left">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="26"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="26"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Grid.Column="0" Classes="Card">
                                <StackPanel>
                                    <TextBlock Text="PATHS" Foreground="{StaticResource Text}" FontWeight="Bold" FontSize="11"/>
                                    <TextBlock Text="// disk locations used by the manager" Foreground="{StaticResource Muted}" FontSize="10" Margin="0,2,0,16"/>

                                    <TextBlock Text="LOCAL MODS.TXT" Classes="SectionLabel" Margin="0,0,0,4"/>
                                    <DockPanel LastChildFill="True" Margin="0,0,0,10">
                                        <Button DockPanel.Dock="Right" Content="BROWSE" Width="72" Margin="6,0,0,0" Click="OnBrowseLocalFile"/>
                                        <TextBlock Text="(uses LocalFilePathTextBox above)" Foreground="{StaticResource Muted}" FontSize="10" VerticalAlignment="Center"/>
                                    </DockPanel>

                                    <TextBlock Text="MODS ROOT" Classes="SectionLabel" Margin="0,4,0,4"/>
                                    <TextBlock Text="(uses ModsRootTextBox in MOD FOLDERS tab)" Foreground="{StaticResource Muted}" FontSize="10"/>

                                    <Border BorderBrush="{StaticResource Line}" BorderThickness="0,1,0,0" Margin="0,14,0,0" Padding="0,10,0,0">
                                        <Button Classes="BtnGreen" Content="💾 SAVE SETTINGS" Click="OnSaveSettings" HorizontalAlignment="Left" Width="180"/>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="0" Grid.Column="2" Classes="Card">
                                <StackPanel>
                                    <TextBlock Text="CONNECTIONS" Foreground="{StaticResource Text}" FontWeight="Bold" FontSize="11"/>
                                    <TextBlock Text="// external services" Foreground="{StaticResource Muted}" FontSize="10" Margin="0,2,0,16"/>

                                    <Border BorderBrush="{StaticResource AccentBorder}" BorderThickness="1"
                                            Background="{StaticResource AccentBg}" Padding="10,8" Margin="0,0,0,10">
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="6" Height="6" Fill="{StaticResource Accent}" VerticalAlignment="Center"/>
                                            <TextBlock Text="STEAM WEB API" Foreground="{StaticResource AccentDim}"
                                                       FontSize="10" FontWeight="Bold" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                            <TextBlock Text=" · ok" Foreground="{StaticResource AccentDim}" FontSize="10" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>

                                    <TextBlock Text="// the keys above are used; leave blank to use the baked-in key."
                                               Foreground="{StaticResource Muted}" FontSize="10" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Classes="Card">
                                <StackPanel>
                                    <TextBlock Text="ABOUT" Foreground="{StaticResource Text}" FontWeight="Bold" FontSize="11"/>
                                    <TextBlock Text="// DayZ Mod Manager — SCP LEGION" Foreground="{StaticResource Muted}" FontSize="10" Margin="0,2,0,12"/>
                                    <TextBlock TextWrapping="Wrap" Foreground="{StaticResource Sub}" FontSize="11">
                                        Manage mods.txt, search Steam Workshop, resolve dependencies, and combine types.xml from local mod folders.
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </ScrollViewer>
                </DockPanel>
            </TabItem>

        </TabControl>
    </Grid>
    </Border>
</Window>
